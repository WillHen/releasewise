{
  "name": "releasewise",
  "version": "0.3.4",
  "description": "AI-powered CLI that turns a git diff into a high-quality release — semver bump, changelog, tag, push, and GitHub Release in one command.",
  "type": "module",
  "bin": {
    "releasewise": "dist/index.js"
  },
  "main": "./dist/index.js",
  "module": "./src/index.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "prepare": "bun run build",
    "build:binary": "bun build src/index.ts --compile --outfile=releasewise",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint --fix src tests",
    "format": "prettier --write \"src/**/*.{ts,json}\" \"tests/**/*.ts\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\" \"tests/**/*.ts\" \"*.{json,md}\"",
    "check": "bun run lint && bun run format:check && bun run typecheck && bun test"
  },
  "keywords": [
    "release",
    "semver",
    "changelog",
    "ai",
    "cli",
    "git",
    "github",
    "conventional-commits"
  ],
  "author": "William Henshaw",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WillHen/releasewise.git"
  },
  "homepage": "https://github.com/WillHen/releasewise",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@google/genai": "^0.3.0",
    "citty": "^0.1.6",
    "openai": "^4.70.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/bun": "latest",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.15.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
